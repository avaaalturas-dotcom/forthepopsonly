<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Father's Day</title>

<style>
body{
    margin:0;
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    font-family:Arial, sans-serif;
}

.container{
    text-align:center;
}

.envelope{
    width:250px;
    height:160px;
    background:#d9b99b;
    position:relative;
    margin:auto;
    border-radius:5px;
}

.envelope:before{
    content:"";
    position:absolute;
    top:0;
    left:0;
    width:0;
    height:0;
    border-left:125px solid transparent;
    border-right:125px solid transparent;
    border-top:80px solid #c69c72;
}

button{
    margin-top:40px;
    padding:12px 28px;
    border:none;
    border-radius:25px;
    background:#8b5e3c;
    color:white;
    font-size:16px;
    cursor:pointer;
    transition:0.3s;
}

button:hover{
    transform:scale(1.1);
	background:#a06d47;
	box-shadow:0 5px 15px rgba(0,0,0,0.2);
}
</style>
</head>

<body>

<div class="card">
<div class="container">
    <div class="envelope">✉️</div>

    <button onclick="window.location.href='letter.html'">
        Open ✉️
    </button>
</div>

</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Happy Father's Day!</title>

<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>

<style>
body{
    margin:0;
    background:#f5efe6;
    display:flex;
    justify-content:center;
    align-items:center;
    height:100vh;
    overflow:hidden;
    font-family:Arial, sans-serif;
}

#photo{
    display:none;
    max-width:80%;
    max-height:80vh;
    border-radius:20px;
    box-shadow:0 5px 20px rgba(0,0,0,0.25);
}

h1{
    position:absolute;
    top:30px;
    color:#8b5e3c;
}
</style>
</head>

<body>

<h1>Congratulations here is your prize!</h1>

<img id="photo" src="tshirtphoto.png" alt="tshirtphoto">

<script>

// Big confetti explosion
confetti({
    particleCount: 300,
    spread: 180,
    origin: { y: 0.6 }
});

// Second burst
setTimeout(() => {
    confetti({
        particleCount: 200,
        spread: 120
    });
}, 800);

// Show photo after 3 seconds
setTimeout(() => {
    document.getElementById("photo").style.display = "block";
}, 3000);

</script>

</body>
</html>
